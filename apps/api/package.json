{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "start": "nest start",
    "build": "nest build",
    "start:prod": "node dist/main.js",
    "prisma:generate": "prisma generate --config=./prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --config=./prisma.config.ts",
    "prisma:deploy": "prisma migrate deploy --config=./prisma.config.ts",
    "seed": "dotenv -e .env -- prisma db seed --config=./prisma.config.ts",
    "seed:test": "dotenv -e .env.test -- prisma db seed --config=./prisma.config.ts",
    "seed:dashboard-sample": "dotenv -e .env -- node scripts/create-dashboard-sample.js",
    "cleanup:dashboard-sample": "dotenv -e .env -- node scripts/cleanup-dashboard-sample.js",
    "postinstall": "prisma generate --config=./prisma.config.ts",
    "pretest:e2e": "dotenv -e .env.test -- prisma migrate deploy --config=./prisma.config.ts",
    "test:e2e": "dotenv -e .env.test -- jest --config ./test/jest-e2e.json --runInBand"
  },
  "prisma": {
    "seed": "dotenv -e .env -- ts-node --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^10.4.22",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.69.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.211.0",
    "@opentelemetry/resources": "^2.5.0",
    "@opentelemetry/sdk-node": "^0.211.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@types/express": "^5.0.6",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "bcryptjs": "^3.0.3",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.22",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.37",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.2.0",
    "prisma": "^7.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.3"
  },
  "overrides": {
    "hono": "^4.12.4",
    "@hono/node-server": "^1.19.10",
    "multer": "^2.1.1"
  }
}
