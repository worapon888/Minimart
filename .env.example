# Root compose flags
ALLOW_DEMO_DATA_MUTATION=false

# API runtime
API_PORT=4000
NODE_ENV=production
WEB_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://minimart:minimart_pw@db:5432/minimart?schema=public
REDIS_URL=redis://redis:6379
JWT_SECRET=replace_with_strong_random_secret
JWT_REFRESH_SECRET=replace_with_strong_random_refresh_secret
REFRESH_TOKEN_DAYS=14
COOKIE_SECURE=false

# API cache/throttle
CACHE_TTL_MS=60000
CACHE_MAX=200
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=1000

# Optional tracing
OTEL_ENABLED=false
OTEL_SERVICE_NAME=minimart-api
OTEL_EXPORTER_OTLP_ENDPOINT=

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# DB bootstrap
POSTGRES_USER=minimart
POSTGRES_PASSWORD=minimart_pw
POSTGRES_DB=minimart
